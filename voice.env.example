# voice_bridge runtime credentials/config — copy to voice.env (gitignored) and source.
# Used by: python -m voice_bridge / zchat voice test --asr volcengine --tts volcengine
# 火山引擎语音服务凭证：https://console.volcengine.com/speech/

# Volcengine 账号 app id + access token (ASR 和 TTS 通常共用)
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=

# ASR (BigModel v3 sauc/bigmodel) — 中英文混合识别
# 默认 zh-CN；强制英文用 en-US；混合用 zh-CN+en-US（控制台 enable）
VOLC_ASR_LANGUAGE=zh-CN
VOLC_ASR_RESOURCE_ID=volc.bigasr.sauc.duration

# TTS (Doubao v1 binary streaming)
VOLC_TTS_CLUSTER=volcano_tts
# 推荐 voice_type 列表（截至 2026）：
#   BV700_streaming                       通用女声流式 (bilingual zh/en，推荐默认)
#   BV001_streaming                       通用女声
#   zh_female_qingxin_emo_v2_mars_bigtts  豆包清新女声 v2 (情感版)
#   zh_male_xiaoming_emo_v2_mars_bigtts   豆包小明 v2
#   en_female_skye_mars_bigtts            英文 Skye
# 完整列表见 https://console.volcengine.com/speech/service/8
VOLC_TTS_VOICE=BV700_streaming
VOLC_TTS_LANGUAGE=cn
VOLC_TTS_SAMPLE_RATE=16000

# voice_portal plugin (在 channel_server 启动时也要 source 这个文件)
VOICE_JWT_SECRET=
VOICE_PORTAL_URL=https://cs.example.com/call
